---
import BaseLayout from "../layouts/BaseLayout.astro";
import { notes } from "../data/notes";

const entries = [...notes].sort(
  (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title="Notes | Garden" pageClass="garden-theme">
  <h1>Notes</h1>
  <p class="subtitle">Fragments, sketches, and questions worth revisiting.</p>

  <section class="garden-intro card">
    <p class="meta">Knowledge Garden</p>
    <p>
      These notes are seeds, not finished essays. Some are sparse, some are
      contradictory, and many are waiting for a future connection.
    </p>
    <p>Follow what feels interesting. Return later. Watch ideas compound.</p>
  </section>

  <section class="list">
    {entries.map((entry) => (
      <article class="card note-card">
        <p class="meta">{dateFormatter.format(new Date(entry.date))}</p>
        <h2>
          <a class="inline-link" href={`/notes/${entry.slug}`}>
            {entry.title}
          </a>
        </h2>
        <p class="note-linkline">
          <a class="inline-link" href={`/notes/${entry.slug}`}>Enter note</a>
        </p>
      </article>
    ))}
  </section>
</BaseLayout>
